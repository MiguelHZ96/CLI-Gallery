[3292.937148, "o", "\u001b[?25l\u001b[1;3H\u001b(B\u001b[m\u001b[32m7\u001b[1;6H\u001b(B\u001b[m\u001b[30m\u001b[1m Time in milliseconds for Elasticsearch to wait for responses from shards. Set \u001b[2;3H\u001b(B\u001b[m\u001b[32m8\u001b[2;5H\u001b(B\u001b[m\u001b[30m\u001b[1m#elasticsearch.shardTimeout: 30000\u001b[3;3H\u001b(B\u001b[m\u001b[32m9\u001b[3;5H\u001b(B\u001b[m                                                                                \u001b[4;2H\u001b(B\u001b[m\u001b[32m90\u001b[4;6H\u001b(B\u001b[m\u001b[30m\u001b[1m Logs qu\u001b[4;15Hries \u001b[4;21Hent to Elasticsearch. Requires logging.verbose set to true.\u001b[5;2H\u001b(B\u001b[m\u001b[32m91\u001b[5;5H\u001b(B\u001b[m\u001b[30m\u001b[1m#elasticsearch.logQueries: false\u001b[6;3H\u001b(B\u001b[m\u001b[32m2\u001b[6;5H\u001b(B\u001b[m                                                                           \u001b[7;3H\u001b(B\u001b[m\u001b[32m3\u001b[7;6H\u001b(B\u001b[m\u001b[30m\u001b[1m Spec\u001b[7;12Hfi\u001b[7;15Hs t\u001b[7;19He path wh\u001b[7;29Hre\u001b[7;32HKibana creates the process ID file.\u001b[8;3H\u001b(B\u001b[m\u001b[32m4\u001b[8;5H\u001b(B\u001b[m\u001b[30m\u001b[1m#pid.file: /run/kibana/kibana.pid\u001b[9;3H\u001b(B\u001b[m\u001b[32m5\u001b[9;5H\u001b(B\u001b[m                                                              \u001b[10;3H\u001b(B\u001b[m\u001b[32m6\u001b[10;6H\u001b(B\u001b[m\u001b[30m\u001b[1m Enables you to specify a file where Kibana stores log output.\u001b[11;3H\u001b(B\u001b[m\u001b[32"]

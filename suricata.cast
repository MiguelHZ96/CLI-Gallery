[1084.206156, "o", "\u001b[?25l\u001b[1;4H\u001b(B\u001b[m\u001b[32m2\u001b[1;29H\u001b(B\u001b[m\u001b[30m\u001b[1mpublish is using a Red\u001b[1;52Hs channel.\u001b[1;63H\"channe\u001b[1;71H\" is\u001b[1;76Han\u001b[1;80Hli\u001b[1;83Hs \u001b[2;4H\u001b(B\u001b[m\u001b[32m3\u001b[2;29H\u001b(B\u001b[m\u001b[30m\u001b[1mxadd is\u001b[2;37Hu\u001b[2;39Hing a Redis stream. \"stream\" is an alias for x\u001b[3;4H\u001b(B\u001b[m\u001b[32m4\u001b[3;15H\u001b(B\u001b[m\u001b[30m\u001b[1mkey:\u001b[3;20Hsuricata\u001b[3;29H## string denoting the key/channel/stream\u001b[3;71Hto\u001b[3;74Huse (defaul\u001b[4;4H\u001b(B\u001b[m\u001b[32m5\u001b[4;15H\u001b(B\u001b[m\u001b[30m\u001b[1mstream-maxlen: 100000  \u001b[4;39H     ## Automatically trims the\u001b[4;71Hstream\u001b[4;78Hlength \u001b[5;4H\u001b(B\u001b[m\u001b[32m6\u001b[5;12H\u001b(B\u001b[m                                \u001b[5;47H\u001b(B\u001b[m\u001b[30m\u001b[1mthis number of events. Se\u001b[5;73H to 0 to dis\u001b[6;4H\u001b(B\u001b[m\u001b[32m7\u001b[6;47H\u001b(B\u001b[m\u001b[30m\u001b[1mOnly\u001b[6;52Hused when\u001b[6;62Hmode is\u001b[6;70Hs\u001b[6;77Hxadd/str\u001b[7;4H\u001b(B\u001b[m\u001b[32m8\u001b[7;12H\u001b(B\u001b[m\u001b[30m\u001b[1m#  stream-trim-exact: false     \u001b[7;47HTrim\u001b[7;52Hexactly to th\u001b[7;67Hmaximum stream len\u001b[8;4H\u001b(B\u001b[m\u001b[32m9\u001b[8;12H\u001b(B\u001b[m                                \u001b[8;47H\u001b(B\u001b[m\u001b[30m\u001b[1mDefault: use\u001b[8;60Hinexact tr\u001b[8;72Hming (inexact\u001b[9;3H\u001b(B\u001b[m\u001b[32m30\u001b[9;47H\u001b(B"]
[1084.206334, "o", "\u001b[m\u001b[30m\u001b[1mt\u001b[9;49Hns of items)\u001b(B\u001b[m                        \u001b[10;4H\u001b(B\u001b[m\u001b[32m1\u001b[10;47H\u001b(B\u001b[m\u001b[30m\u001b[1mOnly\u001b[10;52Hused when mode is set to xadd/str\u001b[11;4H\u001b(B\u001b[m\u001b[32m2\u001b[11;12H\u001b(B\u001b[m\u001b[30m\u001b[1m# Redis pipelining set up. This will enabl\u001b[11;55H to o\u001b[11;61Hly \u001b[11;65Ho\u001b[11;67Ha qu\u001b[11;72Hry every\u001b(B\u001b[m     \u001b[12;4H\u001b(B\u001b[m\u001b[32m3\u001b[12;14H\u001b(B\u001b[m\u001b[30m\u001b[1m'batch-size' events.\u001b[12;35HThis should \u001b[12;48Hower the latency induced by n\u001b[12;78Htwork\u001b[13;4H\u001b(B\u001b[m\u001b[32m4\u001b[13;14H\u001b(B\u001b[m\u001b[30m\u001b[1mconnection at the cost of\u001b[13;41Home mem\u001b[13;49Hry.\u001b[13;53HT\u001b[13;56Hre is no\u001b[13;65Hflushing implemented\u001b[14;4H\u001b(B\u001b[m\u001b[32m5\u001b[14;14H\u001b(B\u001b[m\u001b[30m\u001b[1ms\u001b[14;16H this setting should\u001b[14;37Hbe\u001b[14;40Hres\u001b[14;44Hrv\u001b[14;47Hd to high traffic\u001b[14;65HSuricata\u001b[14;74Hde\u001b[14;78Hoyments\u001b[15;4H\u001b(B\u001b[m\u001b[32m6\u001b[15;14H\u001b(B\u001b[m\u001b[30m\u001b[1m pipelining:\u001b(B\u001b[m                                                           \u001b[16;4H\u001b(B\u001b[m\u001b[32m7\u001b[16;15H\u001b(B\u001b[m\u001b[30m\u001b[1m  enabled: yes ## set enable to yes to enable query pipelining\u001b[17;4H\u001b(B\u001b[m\u001b[32m8\u001b[17;17H\u001b(B\u001b[m\u001b[30m\u001b[1mbatch-si"]
[1084.206382, "o", "ze: 10 ## number of entries to keep\u001b[17;61Hin buffer\u001b(B\u001b[m       \u001b[18;4H\u001b(B\u001b[m\u001b[32m9\u001b[18;12H\u001b(B\u001b[m                                                          \u001b[19;3H\u001b(B\u001b[m\u001b[32m40\u001b[19;12H\u001b(B\u001b[m\u001b[30m\u001b[1m# Include top level metadata. Default yes.\u001b[20;4H\u001b(B\u001b[m\u001b[32m1\u001b[20;13H\u001b(B\u001b[m\u001b[30m\u001b[1mmetadata: no\u001b(B\u001b[m                             \u001b[21;4H\u001b(B\u001b[m\u001b[32m2\u001b[21;13H\u001b(B\u001b[m\u001b[30m\u001b[1m Include suricata version. Default no.\u001b[22;4H\u001b(B\u001b[m\u001b[32m3\u001b[22;13H\u001b(B\u001b[m\u001b[30m\u001b[1msuricata-ve\u001b[22;25Hsion:\u001b[22;31Hy\u001b[22;33Hs\u001b(B\u001b[m                 \u001b[23;4H\u001b(B\u001b[m\u001b[32m4\u001b[23;12H\u001b(B\u001b[m                      \u001b[24;4H\u001b(B\u001b[m\u001b[32m5\u001b[24;12H\u001b(B\u001b[m\u001b[30m\u001b[1m# include the name of the input pcap file in pcap file processing mode\u001b[25;4H\u001b(B\u001b[m\u001b[32m6\u001b[25;12Hpcap-file\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m\u001b[36mfalse\u001b(B\u001b[m                                                      \u001b[26;4H\u001b(B\u001b[m\u001b[32m7\u001b[26;12H\u001b(B\u001b[m                \u001b[27;4H\u001b(B\u001b[m\u001b[32m8\u001b[27;12H\u001b(B\u001b[m\u001b[30m\u001b[1m# Community Flow ID\u001b[28;4H\u001b(B\u001b[m\u001b[32m9\u001b[28;14H\u001b(B\u001b[m\u001b[30m\u001b[1mAdds a 'community_id' field to EVE records. These are meant"]
[1084.20642, "o", " to give\u001b[29;3H\u001b(B\u001b[m\u001b[32m50\u001b[29;14H\u001b(B\u001b[m\u001b[30m\u001b[1mrecords a pred\u001b[29;29Hctable\u001b[29;37Hlow ID that\u001b[29;49Hcan be used to\u001b[29;64Hmatch records to\u001b(B\u001b[m \u001b[30;4H\u001b(B\u001b[m\u001b[32m1\u001b[30;14H\u001b(B\u001b[m\u001b[30m\u001b[1moutput of\u001b[30;24Hother \u001b[30;31Hoo\u001b[30;34Hs\u001b[30;36Hsuch\u001b[30;41Has\u001b[30;44HZeek\u001b[30;49H(Bro).\u001b(B\u001b[m                         \u001b[31;4H\u001b(B\u001b[m\u001b[32m2\u001b[31;13H\u001b(B\u001b[m                                          \u001b[32;4H\u001b(B\u001b[m\u001b[32m3\u001b[32;13H\u001b(B\u001b[m\u001b[30m\u001b[1m Takes a 'seed' that needs to be same across sensors and tools\u001b[33;4H\u001b(B\u001b[m\u001b[32m4\u001b[33;14H\u001b(B\u001b[m\u001b[30m\u001b[1mto make\u001b[33;22Hth\u001b[33;25H id\u001b[33;29Hless\u001b[33;34Hpr\u001b[33;38Hic\u001b[33;41Habl\u001b[33;45H.\u001b(B\u001b[m                             \u001b[34;4H\u001b(B\u001b[m\u001b[32m5\u001b[34;12H\u001b(B\u001b[m                                  \u001b[35;4H\u001b(B\u001b[m\u001b[32m6\u001b[35;12H\u001b(B\u001b[m\u001b[30m\u001b[1m# enable/disable the community id feature.\u001b[36;4H\u001b(B\u001b[m\u001b[32m7\u001b[36;12Hcommunity-id\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m\u001b[36mfalse\u001b(B\u001b[m                       \u001b[37;4H\u001b(B\u001b[m\u001b[31m8\u001b[37;12H\u001b(B\u001b[m\u001b[30m\u001b[1m# Seed value for the ID output. Valid values are 0-65535.\u001b[38;4H\u001b(B\u001b[m\u001b[32m9\u001b[38"]

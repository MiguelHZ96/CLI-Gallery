[1199.482563, "o", "\u001b(B\u001b[m\u001b[32m1\u001b[28;4H6\u001b[28;10H\u001b(B\u001b[m                         \u001b[28;44H\u001b(B\u001b[m\u001b[30m\u001b[1m## this number of events. Set to 0 to dis\u001b[29;2H\u001b(B\u001b[m\u001b[32m1\u001b[29;4H7\u001b[29;10H\u001b(B\u001b[m                        \u001b[29;44H\u001b(B\u001b[m\u001b[30m\u001b[1m## Only used when mode is set to xadd/str\u001b[30;2H\u001b(B\u001b[m\u001b[32m128\u001b[30;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m#  stream-trim-exact: false     ## Trim exactly to the maximum stream len\u001b[31;2H\u001b(B\u001b[m\u001b[32m129\u001b[31;10H\u001b(B\u001b[m                           \u001b[31;44H\u001b(B\u001b[m\u001b[30m\u001b[1m## Default: use inexact trimming (inexact\u001b[32;2H\u001b(B\u001b[m\u001b[32m1\u001b[32;4H0\u001b[32;10H\u001b(B\u001b[m                            \u001b[32;44H\u001b(B\u001b[m\u001b[30m\u001b[1m## tens of items)\u001b[33;2H\u001b(B\u001b[m\u001b[32m1\u001b[33;4H1\u001b[33;10H\u001b(B\u001b[m                       \u001b[33;44H\u001b(B\u001b[m\u001b[30m\u001b[1m## Only used when mode is set to xadd/str\u001b[34;2H\u001b(B\u001b[m\u001b[32m1\u001b[34;4H2\u001b[34;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# Redis pipelining set up. This will enable to only do a query every\u001b[35;2H\u001b(B\u001b[m\u001b[32m1\u001b[35;4H3\u001b[35;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# 'batch-size' events. This should lower the latency induced by network\u001b[36;2H\u001b(B\u001b[m\u001b[32m1\u001b[36;4H4\u001b["]

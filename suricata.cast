[2664.871042, "o", "--------------------------------- Memory -----------------------------------\u001b[20;2H\u001b(B\u001b[m\u001b[32m0\u001b[21;2H1\u001b[21;5H\u001b(B\u001b[m\u001b[30m\u001b[1m L\u001b[21;8Hck the \u001b[21;21H on start\u001b[21;31Hp:\u001b[22;2H\u001b(B\u001b[m\u001b[32m2\u001b[23;2H3\u001b[23;5H\u001b(B\u001b[m\u001b[30m\u001b[1mbootstrap.memory_lock: true\u001b(B\u001b[m                                            \u001b[24;2H\u001b(B\u001b[m\u001b[32m4\u001b[24;5H\u001b(B\u001b[m                                                                       \u001b[25;2H\u001b(B\u001b[m\u001b[32m5\u001b[25;6H\u001b(B\u001b[m\u001b[30m\u001b[1mMake sure that the heap size is set to about half the memory available\u001b[26;2H\u001b(B\u001b[m\u001b[32m6\u001b[26;5H\u001b(B\u001b[m\u001b[30m\u001b[1m on the system and that the owner of the process is allowed to use this\u001b[27;2H\u001b(B\u001b[m\u001b[32m7\u001b[27;6H\u001b(B\u001b[m\u001b[30m\u001b[1mlimi\u001b[27;11H.\u001b(B\u001b[m                                                               \u001b[28;1H\u001b(B\u001b[m\u001b[32m48\u001b[29;1H49\u001b[29;6H\u001b(B\u001b[m\u001b[30m\u001b[1mElasticsearch performs poorly when\u001b[29;41Hthe system is swapping the memory.\u001b(B\u001b[m         \u001b[30;2H\u001b(B\u001b[m\u001b[32m0\u001b[31;2H1\u001b[31;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- N\u001b[31;43Htwork -----------------------------------\u001b[32;"]
[2664.871084, "o", "2H\u001b(B\u001b[m\u001b[32m2\u001b[32;5H\u001b(B\u001b[m                                                 \u001b[33;2H\u001b(B\u001b[m\u001b[32m3\u001b[33;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch is only accessible on localhost. Set a different\u001b[34;2H\u001b(B\u001b[m\u001b[32m4\u001b[34;5H\u001b(B\u001b[m\u001b[30m\u001b[1m address here\u001b[34;19Hto expose this node on the network:\u001b[35;2H\u001b(B\u001b[m\u001b[32m5\u001b[36;2H6\u001b[36;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host: 192.168.0.1\u001b(B\u001b[m                                                   \u001b[37;2H\u001b(B\u001b[m\u001b[32m7\u001b[37;5H\u001b(B\u001b[m                                                       \u001b[38;1H\u001b(B\u001b[m\u001b[32m58\u001b[38;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch listens for HTTP traffic on the first free port it\u001b[39;1H\u001b(B\u001b[m\u001b[32m59\u001b[39;5H\u001b(B\u001b[m\u001b[30m\u001b[1m finds s\u001b[39;14Harting at 9200. Set a specific HTTP port here:\u001b[40;2H\u001b(B\u001b[m\u001b[32m0\u001b[?25l"]
[2664.971101, "o", "\u001b[?25l\u001b[1;1H19\u001b[1;6H\u001b(B\u001b[m\u001b[30m\u001b[1m------------------------------------ Node ------------------------------------\u001b[2;2H\u001b(B\u001b[m\u001b[32m0\u001b[3;2H1\u001b[3;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Us\u001b[3;9H a d\u001b[3;14Hscriptive name for the node:\u001b[4;2H\u001b(B\u001b[m\u001b[32m2\u001b[5;2H3\u001b[5;5H\u001b(B\u001b[m\u001b[30m\u001b[1mno\u001b[5;8He.name: node-1\u001b(B\u001b[m                  \u001b[6;2H\u001b(B\u001b[m\u001b[32m4\u001b[7;2H5\u001b[7;5H\u001b(B\u001b[m\u001b[30m\u001b[1m A\u001b[7;8Hd custom attributes to the node:\u001b[8;2H\u001b(B\u001b[m\u001b[32m6\u001b[9;2H7\u001b[9;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnode.attr.rack: r1\u001b(B\u001b[m                                                             \u001b[10;1H\u001b(B\u001b[m\u001b[32m28\u001b[11;1H29\u001b[11;6H\u001b(B\u001b[m\u001b[30m\u001b[1m----------------------------------- Paths\u001b[11;48H------------------------------------\u001b(B\u001b[m \u001b[12;2H\u001b(B\u001b[m\u001b[32m0\u001b[13;2H1\u001b[13;4H\u001b(B\u001b[m\u001b[30m\u001b[1m# Path to directory where to store the data (separate multiple locations by comma\u001b[14;2H\u001b(B\u001b[m\u001b[32m2\u001b[15;2H3\u001b[15;4Hpath.data\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m/var/lib/elasticsearch\u001b[16;2H\u001b(B\u001b[m\u001b[32m4\u001b[17;2H5\u001b[17;4H\u001b(B\u001b[m\u001b[30m\u001b[1m# Path to log files:\u001b(B\u001b[m             \u001b[18;2H\u001b(B\u001b[m\u001b[32m6\u001b[19;2H7\u001b[19;4Hpath.logs\u001b(B\u001b[m\u001b[33m\u001b[1m:"]
[2664.971242, "o", " \u001b(B\u001b[m/var/log/elasticsearch                                               \u001b[20;1H\u001b(B\u001b[m\u001b[32m38\u001b[21;1H39\u001b[21;6H\u001b(B\u001b[m\u001b[30m\u001b[1m----------------------------------- Memory -----------------------------------\u001b[22;2H\u001b(B\u001b[m\u001b[32m0\u001b[23;2H1\u001b[23;5H\u001b(B\u001b[m\u001b[30m\u001b[1m L\u001b[23;8Hck the \u001b[23;21H on start\u001b[23;31Hp:\u001b[24;2H\u001b(B\u001b[m\u001b[32m2\u001b[25;2H3\u001b[25;5H\u001b(B\u001b[m\u001b[30m\u001b[1mbootstrap.memory_lock: true\u001b(B\u001b[m                                            \u001b[26;2H\u001b(B\u001b[m\u001b[32m4\u001b[26;5H\u001b(B\u001b[m                                                                       \u001b[27;2H\u001b(B\u001b[m\u001b[32m5\u001b[27;6H\u001b(B\u001b[m\u001b[30m\u001b[1mMake sure that the heap size is set to about half the memory available\u001b[28;2H\u001b(B\u001b[m\u001b[32m6\u001b[28;5H\u001b(B\u001b[m\u001b[30m\u001b[1m on the system and that the owner of the process is allowed to use this\u001b[29;2H\u001b(B\u001b[m\u001b[32m7\u001b[29;6H\u001b(B\u001b[m\u001b[30m\u001b[1mlimi\u001b[29;11H.\u001b(B\u001b[m                                                               \u001b[30;1H\u001b(B\u001b[m\u001b[32m48\u001b[31;1H49\u001b[31;6H\u001b(B\u001b[m\u001b[30m\u001b[1mElasticsearch performs poorly when\u001b[31;41Hthe system is swapping the memory.\u001b(B\u001b[m         \u001b[32;2H\u001b(B"]
[2664.971283, "o", "\u001b[m\u001b[32m0\u001b[33;2H1\u001b[33;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- N\u001b[33;43Htwork -----------------------------------\u001b[34;2H\u001b(B\u001b[m\u001b[32m2\u001b[34;5H\u001b(B\u001b[m                                                 \u001b[35;2H\u001b(B\u001b[m\u001b[32m3\u001b[35;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch is only accessible on localhost. Set a different\u001b[36;2H\u001b(B\u001b[m\u001b[32m4\u001b[36;5H\u001b(B\u001b[m\u001b[30m\u001b[1m address here\u001b[36;19Hto expose this node on the network:\u001b[37;2H\u001b(B\u001b[m\u001b[32m5\u001b[38;2H6\u001b[38;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host: 192.168.0.1\u001b(B\u001b[m                                                   \u001b[39;2H\u001b(B\u001b[m\u001b[32m7\u001b[39;5H\u001b(B\u001b[m                                                       \u001b[40;1H\u001b(B\u001b[m\u001b[32m58\u001b[40;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch listens for HTTP traffic on the first free port it\u001b[?25l"]
[2665.089872, "o", "\u001b[?25l\u001b[1;2H\u001b(B\u001b[m\u001b[32m7\u001b[1;5H\u001b(B\u001b[m\u001b[30m\u001b[1mcluster.name: my\u001b[1;22Happlication\u001b(B\u001b[m                                                   \u001b[2;1H\u001b(B\u001b[m\u001b[32m18\u001b[3;1H19\u001b[3;6H\u001b(B\u001b[m\u001b[30m\u001b[1m------------------------------------ Node ------------------------------------\u001b[4;2H\u001b(B\u001b[m\u001b[32m0\u001b[5;2H1\u001b[5;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Us\u001b[5;9H a d\u001b[5;14Hscriptive name for the node:\u001b[6;2H\u001b(B\u001b[m\u001b[32m2\u001b[7;2H3\u001b[7;5H\u001b(B\u001b[m\u001b[30m\u001b[1mno\u001b[7;8He.name: node-1\u001b(B\u001b[m                  \u001b[8;2H\u001b(B\u001b[m\u001b[32m4\u001b[9;2H5\u001b[9;5H\u001b(B\u001b[m\u001b[30m\u001b[1m A\u001b[9;8Hd custom attributes to the node:\u001b[10;2H\u001b(B\u001b[m\u001b[32m6\u001b[11;2H7\u001b[11;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnode.attr.rack: r1\u001b(B\u001b[m                                                             \u001b[12;1H\u001b(B\u001b[m\u001b[32m28\u001b[13;1H29\u001b[13;6H\u001b(B\u001b[m\u001b[30m\u001b[1m----------------------------------- Paths\u001b[13;48H------------------------------------\u001b(B\u001b[m \u001b[14;2H\u001b(B\u001b[m\u001b[32m0\u001b[15;2H1\u001b[15;4H\u001b(B\u001b[m\u001b[30m\u001b[1m# Path to directory where to store the data (separate multiple locations by comma\u001b[16;2H\u001b(B\u001b[m\u001b[32m2\u001b[17;2H3\u001b[17;4Hpath.data\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m/var/lib/elastics"]
[2665.089905, "o", "earch\u001b[18;2H\u001b(B\u001b[m\u001b[32m4\u001b[19;2H5\u001b[19;4H\u001b(B\u001b[m\u001b[30m\u001b[1m# Path to log files:\u001b(B\u001b[m             \u001b[20;2H\u001b(B\u001b[m\u001b[32m6\u001b[21;2H7\u001b[21;4Hpath.logs\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m/var/log/elasticsearch                                               \u001b[22;1H\u001b(B\u001b[m\u001b[32m38\u001b[23;1H39\u001b[23;6H\u001b(B\u001b[m\u001b[30m\u001b[1m----------------------------------- Memory -----------------------------------\u001b[24;2H\u001b(B\u001b[m\u001b[32m0\u001b[25;2H1\u001b[25;5H\u001b(B\u001b[m\u001b[30m\u001b[1m L\u001b[25;8Hck the \u001b[25;21H on start\u001b[25;31Hp:\u001b[26;2H\u001b(B\u001b[m\u001b[32m2\u001b[27;2H3\u001b[27;5H\u001b(B\u001b[m\u001b[30m\u001b[1mbootstrap.memory_lock: true\u001b(B\u001b[m                                            \u001b[28;2H\u001b(B\u001b[m\u001b[32m4\u001b[28;5H\u001b(B\u001b[m                                                                       \u001b[29;2H\u001b(B\u001b[m\u001b[32m5\u001b[29;6H\u001b(B\u001b[m\u001b[30m\u001b[1mMake sure that the heap size is set to about half the memory available\u001b[30;2H\u001b(B\u001b[m\u001b[32m6\u001b[30;5H\u001b(B\u001b[m\u001b[30m\u001b[1m on the system and that the owner of the process is allowed to use this\u001b[31;2H\u001b(B\u001b[m\u001b[32m7\u001b[31;6H\u001b(B\u001b[m\u001b[30m\u001b[1mlimi\u001b[31;11H.\u001b(B\u001b[m                                                               "]
[2665.089935, "o", "\u001b[32;1H\u001b(B\u001b[m\u001b[32m48\u001b[33;1H49\u001b[33;6H\u001b(B\u001b[m\u001b[30m\u001b[1mElasticsearch performs poorly when\u001b[33;41Hthe system is swapping the memory.\u001b(B\u001b[m         \u001b[34;2H\u001b(B\u001b[m\u001b[32m0\u001b[35;2H1\u001b[35;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- N\u001b[35;43Htwork -----------------------------------\u001b[36;2H\u001b(B\u001b[m\u001b[32m2\u001b[36;5H\u001b(B\u001b[m                                                 \u001b[37;2H\u001b(B\u001b[m\u001b[32m3\u001b[37;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch is only accessible on localhost. Set a different\u001b[38;2H\u001b(B\u001b[m\u001b[32m4\u001b[38;5H\u001b(B\u001b[m\u001b[30m\u001b[1m address here\u001b[38;19Hto expose this node on the network:\u001b[39;2H\u001b(B\u001b[m\u001b[32m5\u001b[40;2H6\u001b[40;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host: 192.168.0.1\u001b(B\u001b[m                                                   \u001b[?25l"]
[2665.36088, "o", "\u001b[?25l\u001b[1;2H\u001b(B\u001b[m\u001b[32m5\u001b[1;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Use a descriptive name for your cluster:\u001b[2;2H\u001b(B\u001b[m\u001b[32m6\u001b[3;2H7\u001b[3;5H\u001b(B\u001b[m\u001b[30m\u001b[1mcluster.name: my\u001b[3;22Happlication\u001b(B\u001b[m                                                   \u001b[4;1H\u001b(B\u001b[m\u001b[32m18\u001b[5;1H19\u001b[5;6H\u001b(B\u001b[m\u001b[30m\u001b[1m------------------------------------ Node ------------------------------------\u001b[6;2H\u001b(B\u001b[m\u001b[32m0\u001b[7;2H1\u001b[7;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Us\u001b[7;9H a d\u001b[7;14Hscriptive name for the node:\u001b[8;2H\u001b(B\u001b[m\u001b[32m2\u001b[9;2H3\u001b[9;5H\u001b(B\u001b[m\u001b[30m\u001b[1mno\u001b[9;8He.name: node-1\u001b(B\u001b[m                  \u001b[10;2H\u001b(B\u001b[m\u001b[32m4\u001b[11;2H5\u001b[11;5H\u001b(B\u001b[m\u001b[30m\u001b[1m A\u001b[11;8Hd custom attributes to the node:\u001b[12;2H\u001b(B\u001b[m\u001b[32m6\u001b[13;2H7\u001b[13;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnode.attr.rack: r1\u001b(B\u001b[m                                                             \u001b[14;1H\u001b(B\u001b[m\u001b[32m28\u001b[15;1H29\u001b[15;6H\u001b(B\u001b[m\u001b[30m\u001b[1m----------------------------------- Paths\u001b[15;48H------------------------------------\u001b(B\u001b[m \u001b[16;2H\u001b(B\u001b[m\u001b[32m0\u001b[17;2H1\u001b[17;4H\u001b(B\u001b[m\u001b[30m\u001b[1m# Path to directory where to store the data (separate multiple locations "]
[2665.360914, "o", "by comma\u001b[18;2H\u001b(B\u001b[m\u001b[32m2\u001b[19;2H3\u001b[19;4Hpath.data\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m/var/lib/elasticsearch\u001b[20;2H\u001b(B\u001b[m\u001b[32m4\u001b[21;2H5\u001b[21;4H\u001b(B\u001b[m\u001b[30m\u001b[1m# Path to log files:\u001b(B\u001b[m             \u001b[22;2H\u001b(B\u001b[m\u001b[32m6\u001b[23;2H7\u001b[23;4Hpath.logs\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m/var/log/elasticsearch                                               \u001b[24;1H\u001b(B\u001b[m\u001b[32m38\u001b[25;1H39\u001b[25;6H\u001b(B\u001b[m\u001b[30m\u001b[1m----------------------------------- Memory -----------------------------------\u001b[26;2H\u001b(B\u001b[m\u001b[32m0\u001b[27;2H1\u001b[27;5H\u001b(B\u001b[m\u001b[30m\u001b[1m L\u001b[27;8Hck the \u001b[27;21H on start\u001b[27;31Hp:\u001b[28;2H\u001b(B\u001b[m\u001b[32m2\u001b[29;2H3\u001b[29;5H\u001b(B\u001b[m\u001b[30m\u001b[1mbootstrap.memory_lock: true\u001b(B\u001b[m                                            \u001b[30;2H\u001b(B\u001b[m\u001b[32m4\u001b[30;5H\u001b(B\u001b[m                                                                       \u001b[31;2H\u001b(B\u001b[m\u001b[32m5\u001b[31;6H\u001b(B\u001b[m\u001b[30m\u001b[1mMake sure that the heap size is set to about half the memory available\u001b[32;2H\u001b(B\u001b[m\u001b[32m6\u001b[32;5H\u001b(B\u001b[m\u001b[30m\u001b[1m on the system and that the owner of the process is allowed to use this\u001b[33;2H\u001b(B\u001b[m\u001b[32m7\u001b[33;6H\u001b(B\u001b[m"]

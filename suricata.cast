[2652.25138, "o", "\u001b[?25l\u001b[1;1H\u001b(B\u001b[m\u001b[31m 1 \u001b(B\u001b[m\u001b[30m\u001b[1m# ======================== Elasticsearch Configuration =========================\u001b(B\u001b[m \u001b[2;1H\u001b(B\u001b[m\u001b[32m 2 \u001b(B\u001b[m\u001b[30m\u001b[1m#\u001b(B\u001b[m                                                                                \u001b[3;1H\u001b(B\u001b[m\u001b[32m 3 \u001b(B\u001b[m\u001b[30m\u001b[1m# NOTE: Elasticsearch comes with reasonable defaults for most settings.\u001b(B\u001b[m          \u001b[4;1H\u001b(B\u001b[m\u001b[32m 4 \u001b(B\u001b[m\u001b[30m\u001b[1m#       Before you set out to tweak and tune the configuration, make sure you\u001b(B\u001b[m    \u001b[5;1H\u001b(B\u001b[m\u001b[32m 5 \u001b(B\u001b[m\u001b[30m\u001b[1m#       understand what are you trying to accomplish and the consequences.\u001b(B\u001b[m       \u001b[6;1H\u001b(B\u001b[m\u001b[32m 6 \u001b(B\u001b[m\u001b[30m\u001b[1m#\u001b(B\u001b[m                                                                                \u001b[7;1H\u001b(B\u001b[m\u001b[32m 7 \u001b(B\u001b[m\u001b[30m\u001b[1m# The primary way of configuring a node is via this file. This template lists\u001b(B\u001b[m    \u001b[8;1H\u001b(B\u001b[m\u001b[32m 8 \u001b(B\u001b[m\u001b[30m\u001b[1m# the most important settings you may want to configure for a production cluster.\u001b[9;1H\u001b(B\u001b[m\u001b[32m 9 \u001b(B\u001b[m\u001b[30m\u001b[1m#\u001b(B\u001b[m      "]

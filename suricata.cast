[2763.374316, "o", "\u001b[?25l\u001b[1;1H\u001b(B\u001b[m\u001b[32m31\u001b[1;6H\u001b(B\u001b[m\u001b[30m\u001b[1mPath to directory where to store the data\u001b[1;48H(separate multiple locations by comma\u001b[2;2H\u001b(B\u001b[m\u001b[32m2\u001b[3;2H3\u001b[3;4Hpath.data\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m/var/lib/elasticsearch                                                \u001b[4;2H\u001b(B\u001b[m\u001b[32m4\u001b[5;2H5\u001b[5;4H\u001b(B\u001b[m\u001b[30m\u001b[1m# Path to log files:\u001b(B\u001b[m             \u001b[6;2H\u001b(B\u001b[m\u001b[32m6\u001b[7;2H7\u001b[7;4Hpath.logs\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m/var/log/elasticsearch\u001b[8;2H\u001b(B\u001b[m\u001b[32m8\u001b[9;2H9\u001b[9;4H\u001b(B\u001b[m\u001b[30m\u001b[1m# ----------------------------------- Memory -----------------------------------\u001b[10;1H\u001b(B\u001b[m\u001b[32m40\u001b[11;1H41\u001b[11;6H\u001b(B\u001b[m\u001b[30m\u001b[1mLock the memory on startup:\u001b(B\u001b[m                                                   \u001b[12;2H\u001b(B\u001b[m\u001b[32m2\u001b[13;2H3\u001b[13;5H\u001b(B\u001b[m\u001b[30m\u001b[1mbo\u001b[13;8Htstrap.\u001b[13;21H_lock: tr\u001b[13;31He\u001b(B\u001b[m \u001b[14;2H\u001b(B\u001b[m\u001b[32m4\u001b[15;2H5\u001b[15;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Make sure that the heap size is set to about half the memory available\u001b[16;2H\u001b(B\u001b[m\u001b[32m6\u001b[16;5H\u001b(B\u001b[m\u001b[30m\u001b[1m on the system and that the owner of the process is allowed to use thi"]
[2763.374364, "o", "s\u001b[17;2H\u001b(B\u001b[m\u001b[32m7\u001b[17;6H\u001b(B\u001b[m\u001b[30m\u001b[1mlimit.\u001b(B\u001b[m                                                                \u001b[18;2H\u001b(B\u001b[m\u001b[32m8\u001b[18;5H\u001b(B\u001b[m                                                                       \u001b[19;2H\u001b(B\u001b[m\u001b[32m9\u001b[19;6H\u001b(B\u001b[m\u001b[30m\u001b[1mElas\u001b[19;11Hicsearch performs poorly when the system is swapping the memory.\u001b[20;1H\u001b(B\u001b[m\u001b[32m50\u001b[21;1H51\u001b[21;6H\u001b(B\u001b[m\u001b[30m\u001b[1m----------------------------------\u001b[21;41HNetwork -----------------------------------\u001b[22;2H\u001b(B\u001b[m\u001b[32m2\u001b[23;2H3\u001b[23;6H\u001b(B\u001b[m\u001b[30m\u001b[1mBy default Elasticsearch is only acc\u001b[23;43Hssible on localhost. Set a different\u001b(B\u001b[m     \u001b[24;2H\u001b(B\u001b[m\u001b[32m4\u001b[24;5H\u001b(B\u001b[m\u001b[30m\u001b[1m address here to expose this node on the network:\u001b[25;2H\u001b(B\u001b[m\u001b[32m5\u001b[25;5H\u001b(B\u001b[m                                                                          \u001b[26;2H\u001b(B\u001b[m\u001b[32m6\u001b[26;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host:\u001b[26;19H192.168.0.1\u001b(B\u001b[m                        \u001b[27;1H\u001b(B\u001b[m\u001b[31m57 \u001b(B\u001b[m\u001b[32mnetwork.bind_host\u001b(B\u001b[m\u001b[33m\u001b[1m: [\u001b(B\u001b[m\"127.0.0.1\",\u001b(B\u001b[m\u001b[33m \"172.16.12.246"]
[2763.374558, "o", "\"\u001b(B\u001b[m]\u001b[28;2H\u001b(B\u001b[m\u001b[32m8\u001b[28;5H\u001b(B\u001b[m                         \u001b[29;1H\u001b(B\u001b[m\u001b[32m59 \u001b(B\u001b[m\u001b[30m\u001b[1m# By default Elasticsearch listens for HTTP traffic on the first free port it\u001b[30;1H\u001b(B\u001b[m\u001b[32m60\u001b[30;5H\u001b(B\u001b[m\u001b[30m\u001b[1m finds starting at 9200. Set a specific HTTP port here:\u001b[31;1H\u001b(B\u001b[m\u001b[32m61\u001b[31;5H\u001b(B\u001b[m                                                                            \u001b[32;2H\u001b(B\u001b[m\u001b[32m2\u001b[32;5H\u001b(B\u001b[m\u001b[30m\u001b[1mhttp.por\u001b[32;14H: 9200\u001b(B\u001b[m                                        \u001b[33;2H\u001b(B\u001b[m\u001b[32m3\u001b[34;2H4\u001b[34;5H\u001b(B\u001b[m\u001b[30m\u001b[1m For m\u001b[34;13He information, consult the network module documentation.\u001b[35;2H\u001b(B\u001b[m\u001b[32m5\u001b[36;2H6\u001b[36;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------\u001b[36;40HDisc\u001b[36;45Hvery ----------------------------------\u001b[37;2H\u001b(B\u001b[m\u001b[32m7\u001b[38;2H8\u001b[38;6H\u001b(B\u001b[m\u001b[30m\u001b[1mPass an initial list of hosts to perform discovery when this node is started:\u001b(B\u001b[m \u001b[39;2H\u001b(B\u001b[m\u001b[32m9\u001b[39;5H\u001b(B\u001b[m\u001b[30m\u001b[1m The default list of hosts is [\"127.0.0.1\", \"[::1]\"]\u001b[40;1H\u001b(B\u001b[m\u001b[32m70\u001b[40;5H\u001b(B\u001b[m            "]

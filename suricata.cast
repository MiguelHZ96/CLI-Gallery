[2664.523163, "o", "\u001b[?25l\u001b[1;2H\u001b(B\u001b[m\u001b[32m3\u001b[1;5H\u001b(B\u001b[m\u001b[30m\u001b[1mbootstrap.memory_lock: true\u001b(B\u001b[m                                            \u001b[2;2H\u001b(B\u001b[m\u001b[32m4\u001b[2;5H\u001b(B\u001b[m                                                                       \u001b[3;2H\u001b(B\u001b[m\u001b[32m5\u001b[3;6H\u001b(B\u001b[m\u001b[30m\u001b[1mMake sure that the heap size is set to about half the memory available\u001b[4;2H\u001b(B\u001b[m\u001b[32m6\u001b[4;5H\u001b(B\u001b[m\u001b[30m\u001b[1m on the system and that the owner of the process is allowed to use this\u001b[5;2H\u001b(B\u001b[m\u001b[32m7\u001b[5;6H\u001b(B\u001b[m\u001b[30m\u001b[1mlimi\u001b[5;11H.\u001b(B\u001b[m                                                               \u001b[6;1H\u001b(B\u001b[m\u001b[32m48\u001b[7;1H49\u001b[7;6H\u001b(B\u001b[m\u001b[30m\u001b[1mElasticsearch performs poorly when\u001b[7;41Hthe system is swapping the memory.\u001b(B\u001b[m         \u001b[8;2H\u001b(B\u001b[m\u001b[32m0\u001b[9;2H1\u001b[9;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- N\u001b[9;43Htwork -----------------------------------\u001b[10;2H\u001b(B\u001b[m\u001b[32m2\u001b[10;5H\u001b(B\u001b[m                                                 \u001b[11;2H\u001b(B\u001b[m\u001b[32m3\u001b[11;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch is only accessible on localhost. Set a differe"]
[2664.523281, "o", "nt\u001b[12;2H\u001b(B\u001b[m\u001b[32m4\u001b[12;5H\u001b(B\u001b[m\u001b[30m\u001b[1m address here\u001b[12;19Hto expose this node on the network:\u001b[13;2H\u001b(B\u001b[m\u001b[32m5\u001b[14;2H6\u001b[14;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host: 192.168.0.1\u001b(B\u001b[m                                                   \u001b[15;2H\u001b(B\u001b[m\u001b[32m7\u001b[15;5H\u001b(B\u001b[m                                                       \u001b[16;1H\u001b(B\u001b[m\u001b[32m58\u001b[16;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch listens for HTTP traffic on the first free port it\u001b[17;1H\u001b(B\u001b[m\u001b[32m59\u001b[17;5H\u001b(B\u001b[m\u001b[30m\u001b[1m finds s\u001b[17;14Harting at 9200. Set a specific HTTP port here:\u001b[18;2H\u001b(B\u001b[m\u001b[32m0\u001b[19;2H1\u001b[19;5H\u001b(B\u001b[m\u001b[30m\u001b[1mhttp.p\u001b[19;13Ht: 9200\u001b(B\u001b[m                                                 \u001b[20;2H\u001b(B\u001b[m\u001b[32m2\u001b[21;2H3\u001b[21;6H\u001b(B\u001b[m\u001b[30m\u001b[1mFor more information, consult the\u001b[21;40Hnetw\u001b[21;45Hrk module documentation.\u001b(B\u001b[m               \u001b[22;2H\u001b(B\u001b[m\u001b[32m4\u001b[23;2H5\u001b[23;6H\u001b(B\u001b[m\u001b[30m\u001b[1m--------------------------------- Discovery ----------------------------------\u001b[24;2H\u001b(B\u001b[m\u001b[32m6\u001b[24;5H\u001b(B\u001b[m                                                    \u001b["]
[2664.523342, "o", "25;2H\u001b(B\u001b[m\u001b[32m7\u001b[25;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Pass an initial list of hosts to perform discovery when this node is started:\u001b[26;1H\u001b(B\u001b[m\u001b[32m68\u001b[26;5H\u001b(B\u001b[m\u001b[30m\u001b[1m The d\u001b[26;12Hfault list of hosts is [\"127.0.0.1\", \"[::1]\"]\u001b[27;1H\u001b(B\u001b[m\u001b[32m69\u001b[28;2H0\u001b[28;5H\u001b(B\u001b[m\u001b[30m\u001b[1mdiscove\u001b[28;13Hy.seed_hosts: [\"host1\",\u001b[28;37H\"host2\"]\u001b(B\u001b[m                             \u001b[29;2H\u001b(B\u001b[m\u001b[32m1\u001b[30;2H2\u001b[30;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Boo\u001b[30;10Hstrap \u001b[30;17Hhe clu\u001b[30;27H using an initial set of master-eligible nodes:\u001b[31;2H\u001b(B\u001b[m\u001b[32m3\u001b[32;2H4\u001b[32;5H\u001b(B\u001b[m\u001b[30m\u001b[1mcluster.in\u001b[32;16Htial_master_n\u001b[32;30Hdes: [\"node-1\", \"node-2\"]\u001b(B\u001b[m                              \u001b[33;2H\u001b(B\u001b[m\u001b[32m5\u001b[34;2H6\u001b[34;6H\u001b(B\u001b[m\u001b[30m\u001b[1mFor more information, consult the discovery and cluster formation module docume\u001b[35;2H\u001b(B\u001b[m\u001b[32m7\u001b[36;1H78\u001b[36;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- Various -----------------------------------\u001b[37;1H\u001b(B\u001b[m\u001b[32m79\u001b[38;2H0\u001b[38;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Require explic\u001b[38;21Ht names when deleting indices:\u001b[39;2H\u001b(B\u001b[m\u001b[32m1\u001b[40"]
[2664.523377, "o", ";2H2\u001b[40;5H\u001b(B\u001b[m\u001b[30m\u001b[1maction.destructive_requires_name: tru\u001b[40;43H\u001b(B\u001b[m                                         \u001b[?25l"]
[2664.566908, "o", "\u001b[?25l\u001b[1;2H\u001b(B\u001b[m\u001b[32m1\u001b[1;5H\u001b(B\u001b[m\u001b[30m\u001b[1m L\u001b[1;8Hck the \u001b[1;21H on start\u001b[1;31Hp:\u001b[2;2H\u001b(B\u001b[m\u001b[32m2\u001b[3;2H3\u001b[3;5H\u001b(B\u001b[m\u001b[30m\u001b[1mbootstrap.memory_lock: true\u001b(B\u001b[m                                            \u001b[4;2H\u001b(B\u001b[m\u001b[32m4\u001b[4;5H\u001b(B\u001b[m                                                                       \u001b[5;2H\u001b(B\u001b[m\u001b[32m5\u001b[5;6H\u001b(B\u001b[m\u001b[30m\u001b[1mMake sure that the heap size is set to about half the memory available\u001b[6;2H\u001b(B\u001b[m\u001b[32m6\u001b[6;5H\u001b(B\u001b[m\u001b[30m\u001b[1m on the system and that the owner of the process is allowed to use this\u001b[7;2H\u001b(B\u001b[m\u001b[32m7\u001b[7;6H\u001b(B\u001b[m\u001b[30m\u001b[1mlimi\u001b[7;11H.\u001b(B\u001b[m                                                               \u001b[8;1H\u001b(B\u001b[m\u001b[32m48\u001b[9;1H49\u001b[9;6H\u001b(B\u001b[m\u001b[30m\u001b[1mElasticsearch performs poorly when\u001b[9;41Hthe system is swapping the memory.\u001b(B\u001b[m         \u001b[10;2H\u001b(B\u001b[m\u001b[32m0\u001b[11;2H1\u001b[11;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- N\u001b[11;43Htwork -----------------------------------\u001b[12;2H\u001b(B\u001b[m\u001b[32m2\u001b[12;5H\u001b(B\u001b[m                                                 \u001b[13;2H\u001b(B\u001b[m\u001b[32m3\u001b[13"]
[2664.566953, "o", ";5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch is only accessible on localhost. Set a different\u001b[14;2H\u001b(B\u001b[m\u001b[32m4\u001b[14;5H\u001b(B\u001b[m\u001b[30m\u001b[1m address here\u001b[14;19Hto expose this node on the network:\u001b[15;2H\u001b(B\u001b[m\u001b[32m5\u001b[16;2H6\u001b[16;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host: 192.168.0.1\u001b(B\u001b[m                                                   \u001b[17;2H\u001b(B\u001b[m\u001b[32m7\u001b[17;5H\u001b(B\u001b[m                                                       \u001b[18;1H\u001b(B\u001b[m\u001b[32m58\u001b[18;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch listens for HTTP traffic on the first free port it\u001b[19;1H\u001b(B\u001b[m\u001b[32m59\u001b[19;5H\u001b(B\u001b[m\u001b[30m\u001b[1m finds s\u001b[19;14Harting at 9200. Set a specific HTTP port here:\u001b[20;2H\u001b(B\u001b[m\u001b[32m0\u001b[21;2H1\u001b[21;5H\u001b(B\u001b[m\u001b[30m\u001b[1mhttp.p\u001b[21;13Ht: 9200\u001b(B\u001b[m                                                 \u001b[22;2H\u001b(B\u001b[m\u001b[32m2\u001b[23;2H3\u001b[23;6H\u001b(B\u001b[m\u001b[30m\u001b[1mFor more information, consult the\u001b[23;40Hnetw\u001b[23;45Hrk module documentation.\u001b(B\u001b[m               \u001b[24;2H\u001b(B\u001b[m\u001b[32m4\u001b[25;2H5\u001b[25;6H\u001b(B\u001b[m\u001b[30m\u001b[1m--------------------------------- Discovery ------------------------------"]
[2664.566972, "o", "----\u001b[26;2H\u001b(B\u001b[m\u001b[32m6\u001b[26;5H\u001b(B\u001b[m                                                    \u001b[27;2H\u001b(B\u001b[m\u001b[32m7\u001b[27;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Pass an initial list of hosts to perform discovery when this node is started:\u001b[28;1H\u001b(B\u001b[m\u001b[32m68\u001b[28;5H\u001b(B\u001b[m\u001b[30m\u001b[1m The d\u001b[28;12Hfault list of hosts is [\"127.0.0.1\", \"[::1]\"]\u001b[29;1H\u001b(B\u001b[m\u001b[32m69\u001b[30;2H0\u001b[30;5H\u001b(B\u001b[m\u001b[30m\u001b[1mdiscove\u001b[30;13Hy.seed_hosts: [\"host1\",\u001b[30;37H\"host2\"]\u001b(B\u001b[m                             \u001b[31;2H\u001b(B\u001b[m\u001b[32m1\u001b[32;2H2\u001b[32;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Boo\u001b[32;10Hstrap \u001b[32;17Hhe clu\u001b[32;27H using an initial set of master-eligible nodes:\u001b[33;2H\u001b(B\u001b[m\u001b[32m3\u001b[34;2H4\u001b[34;5H\u001b(B\u001b[m\u001b[30m\u001b[1mcluster.in\u001b[34;16Htial_master_n\u001b[34;30Hdes: [\"node-1\", \"node-2\"]\u001b(B\u001b[m                              \u001b[35;2H\u001b(B\u001b[m\u001b[32m5\u001b[36;2H6\u001b[36;6H\u001b(B\u001b[m\u001b[30m\u001b[1mFor more information, consult the discovery and cluster formation module docume\u001b[37;2H\u001b(B\u001b[m\u001b[32m7\u001b[38;1H78\u001b[38;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- Various -----------------------------------\u001b[39;1H\u001b(B\u001b[m\u001b[32m79\u001b[40;2H0\u001b[40;5H\u001b"]
[2664.566987, "o", "(B\u001b[m\u001b[30m\u001b[1m Require explic\u001b[40;21Ht names when deleting indices:\u001b[?25l"]
[2664.608984, "o", "\u001b[?25l\u001b[1;1H\u001b(B\u001b[m\u001b[32m39\u001b[1;6H\u001b(B\u001b[m\u001b[30m\u001b[1m----------------------------------- Memory -----------------------------------\u001b[2;2H\u001b(B\u001b[m\u001b[32m0\u001b[3;2H1\u001b[3;5H\u001b(B\u001b[m\u001b[30m\u001b[1m L\u001b[3;8Hck the \u001b[3;21H on start\u001b[3;31Hp:\u001b[4;2H\u001b(B\u001b[m\u001b[32m2\u001b[5;2H3\u001b[5;5H\u001b(B\u001b[m\u001b[30m\u001b[1mbootstrap.memory_lock: true\u001b(B\u001b[m                                            \u001b[6;2H\u001b(B\u001b[m\u001b[32m4\u001b[6;5H\u001b(B\u001b[m                                                                       \u001b[7;2H\u001b(B\u001b[m\u001b[32m5\u001b[7;6H\u001b(B\u001b[m\u001b[30m\u001b[1mMake sure that the heap size is set to about half the memory available\u001b[8;2H\u001b(B\u001b[m\u001b[32m6\u001b[8;5H\u001b(B\u001b[m\u001b[30m\u001b[1m on the system and that the owner of the process is allowed to use this\u001b[9;2H\u001b(B\u001b[m\u001b[32m7\u001b[9;6H\u001b(B\u001b[m\u001b[30m\u001b[1mlimi\u001b[9;11H.\u001b(B\u001b[m                                                               \u001b[10;1H\u001b(B\u001b[m\u001b[32m48\u001b[11;1H49\u001b[11;6H\u001b(B\u001b[m\u001b[30m\u001b[1mElasticsearch performs poorly when\u001b[11;41Hthe system is swapping the memory.\u001b(B\u001b[m         \u001b[12;2H\u001b(B\u001b[m\u001b[32m0\u001b[13;2H1\u001b[13;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- N\u001b[13;43Htwork ----------"]
[2664.609015, "o", "-------------------------\u001b[14;2H\u001b(B\u001b[m\u001b[32m2\u001b[14;5H\u001b(B\u001b[m                                                 \u001b[15;2H\u001b(B\u001b[m\u001b[32m3\u001b[15;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch is only accessible on localhost. Set a different\u001b[16;2H\u001b(B\u001b[m\u001b[32m4\u001b[16;5H\u001b(B\u001b[m\u001b[30m\u001b[1m address here\u001b[16;19Hto expose this node on the network:\u001b[17;2H\u001b(B\u001b[m\u001b[32m5\u001b[18;2H6\u001b[18;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host: 192.168.0.1\u001b(B\u001b[m                                                   \u001b[19;2H\u001b(B\u001b[m\u001b[32m7\u001b[19;5H\u001b(B\u001b[m                                                       \u001b[20;1H\u001b(B\u001b[m\u001b[32m58\u001b[20;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch listens for HTTP traffic on the first free port it\u001b[21;1H\u001b(B\u001b[m\u001b[32m59\u001b[21;5H\u001b(B\u001b[m\u001b[30m\u001b[1m finds s\u001b[21;14Harting at 9200. Set a specific HTTP port here:\u001b[22;2H\u001b(B\u001b[m\u001b[32m0\u001b[23;2H1\u001b[23;5H\u001b(B\u001b[m\u001b[30m\u001b[1mhttp.p\u001b[23;13Ht: 9200\u001b(B\u001b[m                                                 \u001b[24;2H\u001b(B\u001b[m\u001b[32m2\u001b[25;2H3\u001b[25;6H\u001b(B\u001b[m\u001b[30m\u001b[1mFor more information, consult the\u001b[25;40Hnetw\u001b[25;45Hrk module documentation.\u001b(B\u001b[m         "]
[2664.609028, "o", "      \u001b[26;2H\u001b(B\u001b[m\u001b[32m4\u001b[27;2H5\u001b[27;6H\u001b(B\u001b[m\u001b[30m\u001b[1m--------------------------------- Discovery ----------------------------------\u001b[28;2H\u001b(B\u001b[m\u001b[32m6\u001b[28;5H\u001b(B\u001b[m                                                    \u001b[29;2H\u001b(B\u001b[m\u001b[32m7\u001b[29;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Pass an initial list of hosts to perform discovery when this node is started:\u001b[30;1H\u001b(B\u001b[m\u001b[32m68\u001b[30;5H\u001b(B\u001b[m\u001b[30m\u001b[1m The d\u001b[30;12Hfault list of hosts is [\"127.0.0.1\", \"[::1]\"]\u001b[31;1H\u001b(B\u001b[m\u001b[32m69\u001b[32;2H0\u001b[32;5H\u001b(B\u001b[m\u001b[30m\u001b[1mdiscove\u001b[32;13Hy.seed_hosts: [\"host1\",\u001b[32;37H\"host2\"]\u001b(B\u001b[m                             \u001b[33;2H\u001b(B\u001b[m\u001b[32m1\u001b[34;2H2\u001b[34;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Boo\u001b[34;10Hstrap \u001b[34;17Hhe clu\u001b[34;27H using an initial set of master-eligible nodes:\u001b[35;2H\u001b(B\u001b[m\u001b[32m3\u001b[36;2H4\u001b[36;5H\u001b(B\u001b[m\u001b[30m\u001b[1mcluster.in\u001b[36;16Htial_master_n\u001b[36;30Hdes: [\"node-1\", \"node-2\"]\u001b(B\u001b[m                              \u001b[37;2H\u001b(B\u001b[m\u001b[32m5\u001b[38;2H6\u001b[38;6H\u001b(B\u001b[m\u001b[30m\u001b[1mFor more information, consult the discovery and cluster formation module docume\u001b[39;2H\u001b(B\u001b[m\u001b[32m7\u001b[40;1H78\u001b[40;6H"]

[2664.749804, "o", "de on the network:\u001b[29;2H\u001b(B\u001b[m\u001b[32m5\u001b[30;2H6\u001b[30;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host: 192.168.0.1\u001b(B\u001b[m                                                   \u001b[31;2H\u001b(B\u001b[m\u001b[32m7\u001b[31;5H\u001b(B\u001b[m                                                       \u001b[32;1H\u001b(B\u001b[m\u001b[32m58\u001b[32;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch listens for HTTP traffic on the first free port it\u001b[33;1H\u001b(B\u001b[m\u001b[32m59\u001b[33;5H\u001b(B\u001b[m\u001b[30m\u001b[1m finds s\u001b[33;14Harting at 9200. Set a specific HTTP port here:\u001b[34;2H\u001b(B\u001b[m\u001b[32m0\u001b[35;2H1\u001b[35;5H\u001b(B\u001b[m\u001b[30m\u001b[1mhttp.p\u001b[35;13Ht: 9200\u001b(B\u001b[m                                                 \u001b[36;2H\u001b(B\u001b[m\u001b[32m2\u001b[37;2H3\u001b[37;6H\u001b(B\u001b[m\u001b[30m\u001b[1mFor more information, consult the\u001b[37;40Hnetw\u001b[37;45Hrk module documentation.\u001b(B\u001b[m               \u001b[38;2H\u001b(B\u001b[m\u001b[32m4\u001b[39;2H5\u001b[39;6H\u001b(B\u001b[m\u001b[30m\u001b[1m--------------------------------- Discovery ----------------------------------\u001b[40;2H\u001b(B\u001b[m\u001b[32m6\u001b[40;5H\u001b(B\u001b[m                                                    \u001b[?25l"]

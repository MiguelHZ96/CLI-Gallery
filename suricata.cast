[2665.50381, "o", "                                 \u001b[32;1H\u001b(B\u001b[m\u001b[32m38\u001b[33;1H39\u001b[33;6H\u001b(B\u001b[m\u001b[30m\u001b[1m----------------------------------- Memory -----------------------------------\u001b[34;2H\u001b(B\u001b[m\u001b[32m0\u001b[35;2H1\u001b[35;5H\u001b(B\u001b[m\u001b[30m\u001b[1m L\u001b[35;8Hck the \u001b[35;21H on start\u001b[35;31Hp:\u001b[36;2H\u001b(B\u001b[m\u001b[32m2\u001b[37;2H3\u001b[37;5H\u001b(B\u001b[m\u001b[30m\u001b[1mbootstrap.memory_lock: true\u001b(B\u001b[m                                            \u001b[38;2H\u001b(B\u001b[m\u001b[32m4\u001b[38;5H\u001b(B\u001b[m                                                                       \u001b[39;2H\u001b(B\u001b[m\u001b[32m5\u001b[39;6H\u001b(B\u001b[m\u001b[30m\u001b[1mMake sure that the heap size is set to about half the memory available\u001b[40;2H\u001b(B\u001b[m\u001b[32m6\u001b[40;5H\u001b(B\u001b[m\u001b[30m\u001b[1m on the system and that the owner of the process is allowed to use this\u001b[?25l"]

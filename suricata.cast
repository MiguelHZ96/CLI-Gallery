[1077.143412, "o", "\u001b[?25l\u001b[1;1H\u001b(B\u001b[m\u001b[32m 121 \u001b(B\u001b[m     \u001b[1;12H\u001b(B\u001b[m\u001b[30m\u001b[1m#             ## lpush and rpush are using a Redis list. \"list\" is an ali\u001b[2;2H\u001b(B\u001b[m\u001b[32m12\u001b[2;6H\u001b(B\u001b[m   \u001b[2;12H\u001b(B\u001b[m\u001b[30m\u001b[1m#             ## publish is using a Redis channel. \"channel\" is an alias \u001b[3;2H\u001b(B\u001b[m\u001b[32m12\u001b[3;12H\u001b(B\u001b[m\u001b[30m\u001b[1m#             ## xadd is using a Redis stream. \"stream\" is an alias for x\u001b[4;2H\u001b(B\u001b[m\u001b[32m12\u001b[4;6H\u001b(B\u001b[m      \u001b(B\u001b[m\u001b[30m\u001b[1m#  key: suric\u001b[4;27Ha ## string denoting the\u001b[4;52Hkey/\u001b[4;57Hhannel/stream to use (defaul\u001b[5;2H\u001b(B\u001b[m\u001b[32m12\u001b[5;6H\u001b(B\u001b[m      \u001b(B\u001b[m\u001b[30m\u001b[1m#  stream-maxlen:\u001b[5;30H100000        ## Automatically trims the stream length \u001b[6;2H\u001b(B\u001b[m\u001b[32m12\u001b[6;6H\u001b(B\u001b[m                                      \u001b(B\u001b[m\u001b[30m\u001b[1m## this number of events. Se\u001b[6;73H to 0 to dis\u001b[7;2H\u001b(B\u001b[m\u001b[32m12\u001b[7;44H\u001b(B\u001b[m\u001b[30m\u001b[1m## Only used when mode is set to xadd/str\u001b[8;2H\u001b(B\u001b[m\u001b[32m12\u001b[8;6H\u001b(B\u001b[m      \u001b(B\u001b[m\u001b[30m\u001b[1m#  stream-\u001b[8;23Hrim-exact: false     ## Trim ex\u001b[8;55Hctly to the maximum stream len\u001b[9;2H\u001b(B\u001b[m\u001b[32m12\u001b[9;6"]
[1077.14355, "o", "H\u001b(B\u001b[m                       \u001b[9;44H\u001b(B\u001b[m\u001b[30m\u001b[1m## Default: use inexact trimming (inexact\u001b[10;2H\u001b(B\u001b[m\u001b[32m13\u001b[10;44H\u001b(B\u001b[m\u001b[30m\u001b[1m## tens of items)\u001b[11;2H\u001b(B\u001b[m\u001b[32m13\u001b[11;6H\u001b(B\u001b[m  \u001b[11;44H\u001b(B\u001b[m\u001b[30m\u001b[1m## Only used when mode is set to xadd/str\u001b[12;2H\u001b(B\u001b[m\u001b[32m13\u001b[12;6H\u001b(B\u001b[m      \u001b(B\u001b[m\u001b[30m\u001b[1m#\u001b[12;14HRedis pipelin\u001b[12;28Hng set up.\u001b[12;39HThis\u001b[12;44Hwill enable to only do a query every\u001b[13;2H\u001b(B\u001b[m\u001b[32m13\u001b[13;6H\u001b(B\u001b[m  \u001b[13;12H\u001b(B\u001b[m\u001b[30m\u001b[1m# 'batch-size' events. This should lower the latency induced by network\u001b[14;2H\u001b(B\u001b[m\u001b[32m13\u001b[14;12H\u001b(B\u001b[m\u001b[30m\u001b[1m# connection at the cost of some memory. There is no flushing implemented\u001b[15;2H\u001b(B\u001b[m\u001b[32m13\u001b[15;6H\u001b(B\u001b[m     \u001b[15;12H\u001b(B\u001b[m\u001b[30m\u001b[1m# so this setting should be reserved to high traffic Suricata deployments\u001b[16;2H\u001b(B\u001b[m\u001b[32m13\u001b[16;8H\u001b(B\u001b[m    \u001b(B\u001b[m\u001b[30m\u001b[1m# \u001b[16;15Hpipelining:\u001b(B\u001b[m                                          \u001b[17;2H\u001b(B\u001b[m\u001b[32m13\u001b[17;8H\u001b(B\u001b[m    \u001b(B\u001b[m\u001b[30m\u001b[1m#    enabled: yes ## set enable to yes to enable query pipelining\u001b[18;"]
[1077.143574, "o", "2H\u001b(B\u001b[m\u001b[32m13\u001b[18;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m#    batch-size: 10 ## number of entries to keep in buffer\u001b[19;2H\u001b(B\u001b[m\u001b[32m13\u001b[19;10H\u001b(B\u001b[m                             \u001b[20;2H\u001b(B\u001b[m\u001b[32m14\u001b[20;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# Include top level metadata. Default yes.\u001b[21;2H\u001b(B\u001b[m\u001b[32m14\u001b[21;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m#metadata: no\u001b(B\u001b[m             \u001b[22;2H\u001b(B\u001b[m\u001b[32m14\u001b[22;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# Include suricata version. Default no.\u001b[23;2H\u001b(B\u001b[m\u001b[32m14\u001b[23;12H\u001b(B\u001b[m\u001b[30m\u001b[1m#suricata-version: yes\u001b[24;2H\u001b(B\u001b[m\u001b[32m14\u001b[24;10H\u001b(B\u001b[m                          \u001b[25;2H\u001b(B\u001b[m\u001b[32m14\u001b[25;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# include the name of the input pcap file in pcap file processing mode\u001b[26;2H\u001b(B\u001b[m\u001b[32m14\u001b[26;12Hpcap-file\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m\u001b[36mfalse\u001b[27;2H\u001b(B\u001b[m\u001b[32m14\u001b[27;10H\u001b(B\u001b[m                         \u001b[28;2H\u001b(B\u001b[m\u001b[32m14\u001b[28;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# Community Flow ID\u001b(B\u001b[m    \u001b[29;2H\u001b(B\u001b[m\u001b[32m14\u001b[29;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# Adds a 'community_id' field to EVE records. These are meant to give\u001b[30;2H\u001b(B\u001b[m\u001b[3"]
[1077.143588, "o", "2m15\u001b[30;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# records a predictable flow ID that can be used to match records to\u001b[31;2H\u001b(B\u001b[m\u001b[32m15\u001b[31;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# output of other tools such as Zeek (Bro).\u001b[32;2H\u001b(B\u001b[m\u001b[32m15\u001b[32;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m#\u001b(B\u001b[m                         \u001b[33;2H\u001b(B\u001b[m\u001b[32m15\u001b[33;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# Takes a 'seed' that needs to be same across sensors and tools\u001b[34;2H\u001b(B\u001b[m\u001b[32m15\u001b[34;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# to make the id less predictable.\u001b[35;2H\u001b(B\u001b[m\u001b[32m15\u001b[35;10H\u001b(B\u001b[m                        \u001b[36;2H\u001b(B\u001b[m\u001b[32m15\u001b[36;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# enable/disable the community id feature.\u001b[37;1H\u001b(B\u001b[m\u001b[31m 157 \u001b[37;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[7mcommunity-id\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m\u001b[36mfalse\u001b(B\u001b[m     \u001b[38;2H\u001b(B\u001b[m\u001b[32m15\u001b[38;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[30m\u001b[1m# Seed value for the ID output. Valid values are 0-65535.\u001b[39;2H\u001b(B\u001b[m\u001b[32m15\u001b[39;10H\u001b(B\u001b[m  \u001b(B\u001b[m\u001b[32mcommunity-id-seed\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m0  \u001b[40;2H\u001b(B\u001b[m\u001b[32m16\u001b[41;31H\u001b(B\u001b[m\u001b[37;44m57,19) | ft:yaml | unix | utf-8Alt-g: b\u001b[41;72Hdi"]

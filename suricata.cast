[2664.651208, "o", "\u001b[?25l\u001b[1;2H\u001b(B\u001b[m\u001b[32m5\u001b[1;4H\u001b(B\u001b[m\u001b[30m\u001b[1m# Path to log files:\u001b(B\u001b[m             \u001b[2;2H\u001b(B\u001b[m\u001b[32m6\u001b[3;2H7\u001b[3;4Hpath.logs\u001b(B\u001b[m\u001b[33m\u001b[1m: \u001b(B\u001b[m/var/log/elasticsearch                                               \u001b[4;1H\u001b(B\u001b[m\u001b[32m38\u001b[5;1H39\u001b[5;6H\u001b(B\u001b[m\u001b[30m\u001b[1m----------------------------------- Memory -----------------------------------\u001b[6;2H\u001b(B\u001b[m\u001b[32m0\u001b[7;2H1\u001b[7;5H\u001b(B\u001b[m\u001b[30m\u001b[1m L\u001b[7;8Hck the \u001b[7;21H on start\u001b[7;31Hp:\u001b[8;2H\u001b(B\u001b[m\u001b[32m2\u001b[9;2H3\u001b[9;5H\u001b(B\u001b[m\u001b[30m\u001b[1mbootstrap.memory_lock: true\u001b(B\u001b[m                                            \u001b[10;2H\u001b(B\u001b[m\u001b[32m4\u001b[10;5H\u001b(B\u001b[m                                                                       \u001b[11;2H\u001b(B\u001b[m\u001b[32m5\u001b[11;6H\u001b(B\u001b[m\u001b[30m\u001b[1mMake sure that the heap size is set to about half the memory available\u001b[12;2H\u001b(B\u001b[m\u001b[32m6\u001b[12;5H\u001b(B\u001b[m\u001b[30m\u001b[1m on the system and that the owner of the process is allowed to use this\u001b[13;2H\u001b(B\u001b[m\u001b[32m7\u001b[13;6H\u001b(B\u001b[m\u001b[30m\u001b[1mlimi\u001b[13;11H.\u001b(B\u001b[m                                                               \u001b[14;1H\u001b(B\u001b[m\u001b[32m48\u001b[15"]
[2664.651389, "o", ";1H49\u001b[15;6H\u001b(B\u001b[m\u001b[30m\u001b[1mElasticsearch performs poorly when\u001b[15;41Hthe system is swapping the memory.\u001b(B\u001b[m         \u001b[16;2H\u001b(B\u001b[m\u001b[32m0\u001b[17;2H1\u001b[17;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- N\u001b[17;43Htwork -----------------------------------\u001b[18;2H\u001b(B\u001b[m\u001b[32m2\u001b[18;5H\u001b(B\u001b[m                                                 \u001b[19;2H\u001b(B\u001b[m\u001b[32m3\u001b[19;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch is only accessible on localhost. Set a different\u001b[20;2H\u001b(B\u001b[m\u001b[32m4\u001b[20;5H\u001b(B\u001b[m\u001b[30m\u001b[1m address here\u001b[20;19Hto expose this node on the network:\u001b[21;2H\u001b(B\u001b[m\u001b[32m5\u001b[22;2H6\u001b[22;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host: 192.168.0.1\u001b(B\u001b[m                                                   \u001b[23;2H\u001b(B\u001b[m\u001b[32m7\u001b[23;5H\u001b(B\u001b[m                                                       \u001b[24;1H\u001b(B\u001b[m\u001b[32m58\u001b[24;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch listens for HTTP traffic on the first free port it\u001b[25;1H\u001b(B\u001b[m\u001b[32m59\u001b[25;5H\u001b(B\u001b[m\u001b[30m\u001b[1m finds s\u001b[25;14Harting at 9200. Set a specific HTTP port here:\u001b[26;2H\u001b(B\u001b[m\u001b[32m0\u001b[27;2H1\u001b[27;5H\u001b(B\u001b["]
[2664.65151, "o", "m\u001b[30m\u001b[1mhttp.p\u001b[27;13Ht: 9200\u001b(B\u001b[m                                                 \u001b[28;2H\u001b(B\u001b[m\u001b[32m2\u001b[29;2H3\u001b[29;6H\u001b(B\u001b[m\u001b[30m\u001b[1mFor more information, consult the\u001b[29;40Hnetw\u001b[29;45Hrk module documentation.\u001b(B\u001b[m               \u001b[30;2H\u001b(B\u001b[m\u001b[32m4\u001b[31;2H5\u001b[31;6H\u001b(B\u001b[m\u001b[30m\u001b[1m--------------------------------- Discovery ----------------------------------\u001b[32;2H\u001b(B\u001b[m\u001b[32m6\u001b[32;5H\u001b(B\u001b[m                                                    \u001b[33;2H\u001b(B\u001b[m\u001b[32m7\u001b[33;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Pass an initial list of hosts to perform discovery when this node is started:\u001b[34;1H\u001b(B\u001b[m\u001b[32m68\u001b[34;5H\u001b(B\u001b[m\u001b[30m\u001b[1m The d\u001b[34;12Hfault list of hosts is [\"127.0.0.1\", \"[::1]\"]\u001b[35;1H\u001b(B\u001b[m\u001b[32m69\u001b[36;2H0\u001b[36;5H\u001b(B\u001b[m\u001b[30m\u001b[1mdiscove\u001b[36;13Hy.seed_hosts: [\"host1\",\u001b[36;37H\"host2\"]\u001b(B\u001b[m                             \u001b[37;2H\u001b(B\u001b[m\u001b[32m1\u001b[38;2H2\u001b[38;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Boo\u001b[38;10Hstrap \u001b[38;17Hhe clu\u001b[38;27H using an initial set of master-eligible nodes:\u001b[39;2H\u001b(B\u001b[m\u001b[32m3\u001b[40;2H4\u001b[40;5H\u001b(B\u001b[m\u001b[30m\u001b[1mcluster.in\u001b[40;16Htial_master_n\u001b[40;"]

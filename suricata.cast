[2763.908318, "o", "\u001b[?25l\u001b[1;2H\u001b(B\u001b[m\u001b[32m7\u001b[2;2H8\u001b[2;6H\u001b(B\u001b[m\u001b[30m\u001b[1mPass an initial list of hosts to perform discovery when this node is started:\u001b(B\u001b[m \u001b[3;2H\u001b(B\u001b[m\u001b[32m9\u001b[3;5H\u001b(B\u001b[m\u001b[30m\u001b[1m The default list of hosts is [\"127.0.0.1\", \"[::1]\"]\u001b[4;1H\u001b(B\u001b[m\u001b[32m70\u001b[4;5H\u001b(B\u001b[m                                                                              \u001b[5;1H\u001b(B\u001b[m\u001b[32m71\u001b[5;5H\u001b(B\u001b[m\u001b[30m\u001b[1mdiscov\u001b[5;12Hry.seed_hosts: [\"host1\", \"host2\"]\u001b(B\u001b[m            \u001b[6;2H\u001b(B\u001b[m\u001b[32m2\u001b[7;2H3\u001b[7;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Bootst\u001b[7;13Hap the cluster using an\u001b[7;37Hinitial set of master-eligible nodes:\u001b[8;2H\u001b(B\u001b[m\u001b[32m4\u001b[9;2H5\u001b[9;5H\u001b(B\u001b[m\u001b[30m\u001b[1mclus\u001b[9;10Her.ini\u001b[9;17Hial_ma\u001b[9;27H_nodes: [\"node-1\", \"node-2\"]\u001b(B\u001b[m                   \u001b[10;2H\u001b(B\u001b[m\u001b[32m6\u001b[11;2H7\u001b[11;5H\u001b(B\u001b[m\u001b[30m\u001b[1m For more \u001b[11;16Hnformation, c\u001b[11;30Hnsult the discovery and cluster formation module docume\u001b[12;2H\u001b(B\u001b[m\u001b[32m8\u001b[13;2H9\u001b[13;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- Various -----------------------------------\u001b(B\u001b[m \u001b[14;1H\u001b(B\u001b[m\u001b[32m80\u001b[15;1H81\u001b[15;6H\u001b(B\u001b[m\u001b["]

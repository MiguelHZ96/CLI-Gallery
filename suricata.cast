[3340.018213, "o", "\u001b[?25l\u001b[1;1H\u001b(B\u001b[m\u001b[32m  4\u001b[1;6H\u001b(B\u001b[m\u001b[30m\u001b[1m Specifies the\u001b[1;21Haddr\u001b[1;26Hss to which the Kibana server will bind. IP addresses and h\u001b[2;1H\u001b(B\u001b[m\u001b[32m  5\u001b[2;5H\u001b(B\u001b[m\u001b[30m\u001b[1m# The default is 'localhost', which usually means remote machines will not be ab\u001b[3;1H\u001b(B\u001b[m\u001b[32m  6\u001b[3;7H\u001b(B\u001b[m\u001b[30m\u001b[1mTo allow connections from remo\u001b[3;38He\u001b[3;40Husers, set this\u001b[3;56Hparameter to a \u001b[3;72Hon-loopback a\u001b[4;1H\u001b(B\u001b[m\u001b[31m  7 \u001b[4;6H\u001b(B\u001b[m\u001b[7mserver.host\u001b(B\u001b[m\u001b[30m\u001b[1m: \"localhost\"\u001b[5;1H\u001b(B\u001b[m\u001b[32m  8\u001b[5;5H\u001b(B\u001b[m                       \u001b[6;1H\u001b(B\u001b[m\u001b[32m  9\u001b[6;5H\u001b(B\u001b[m\u001b[30m\u001b[1m# Enables you to specify a path to mount Kibana at if you are running behind a p\u001b[7;1H\u001b(B\u001b[m\u001b[32m 10\u001b[7;7H\u001b(B\u001b[m\u001b[30m\u001b[1mUse\u001b[7;15H`server.rewriteBa\u001b[7;34HPath`\u001b[7;40Hsetting to tell Kibana if it\u001b[7;69Hshould remove th\u001b[8;1H\u001b(B\u001b[m\u001b[32m \u001b[8;3H1\u001b[8;7H\u001b(B\u001b[m\u001b[30m\u001b[1mfrom requests it\u001b[8;24Hreceive\u001b[8;32H,\u001b[8;34Hand to prevent a deprecation warning at startup.\u001b[9;1H\u001b(B\u001b[m\u001b[32m \u001b[9;3H2\u001b[9;6H\u001b(B\u001b[m\u001b[30m\u001b[1m This s\u001b[9;14Htting\u001b[9;20Hcannot end in a slash"]

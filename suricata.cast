[2664.131072, "o", "\u001b[?25l\u001b[1;1H\u001b(B\u001b[m\u001b[32m49\u001b[1;6H\u001b(B\u001b[m\u001b[30m\u001b[1mElasticsearch performs poorly when\u001b[1;41Hthe system is swapping the memory.\u001b(B\u001b[m         \u001b[2;2H\u001b(B\u001b[m\u001b[32m0\u001b[3;2H1\u001b[3;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- N\u001b[3;43Htwork -----------------------------------\u001b[4;2H\u001b(B\u001b[m\u001b[32m2\u001b[4;5H\u001b(B\u001b[m                                                 \u001b[5;2H\u001b(B\u001b[m\u001b[32m3\u001b[5;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch is only accessible on localhost. Set a different\u001b[6;2H\u001b(B\u001b[m\u001b[32m4\u001b[6;5H\u001b(B\u001b[m\u001b[30m\u001b[1m address here\u001b[6;19Hto expose this node on the network:\u001b[7;2H\u001b(B\u001b[m\u001b[32m5\u001b[8;2H6\u001b[8;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host: 192.168.0.1\u001b(B\u001b[m                                                   \u001b[9;2H\u001b(B\u001b[m\u001b[32m7\u001b[9;5H\u001b(B\u001b[m                                                       \u001b[10;1H\u001b(B\u001b[m\u001b[32m58\u001b[10;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch listens for HTTP traffic on the first free port it\u001b[11;1H\u001b(B\u001b[m\u001b[32m59\u001b[11;5H\u001b(B\u001b[m\u001b[30m\u001b[1m finds s\u001b[11;14Harting at 9200. Set a specific HTTP port here:\u001b[12;2H\u001b(B\u001b[m\u001b[32m0\u001b[13;2H1\u001b[13;5H\u001b(B"]
[2664.131247, "o", "\u001b[m\u001b[30m\u001b[1mhttp.p\u001b[13;13Ht: 9200\u001b(B\u001b[m                                                 \u001b[14;2H\u001b(B\u001b[m\u001b[32m2\u001b[15;2H3\u001b[15;6H\u001b(B\u001b[m\u001b[30m\u001b[1mFor more information, consult the\u001b[15;40Hnetw\u001b[15;45Hrk module documentation.\u001b(B\u001b[m               \u001b[16;2H\u001b(B\u001b[m\u001b[32m4\u001b[17;2H5\u001b[17;6H\u001b(B\u001b[m\u001b[30m\u001b[1m--------------------------------- Discovery ----------------------------------\u001b[18;2H\u001b(B\u001b[m\u001b[32m6\u001b[18;5H\u001b(B\u001b[m                                                    \u001b[19;2H\u001b(B\u001b[m\u001b[32m7\u001b[19;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Pass an initial list of hosts to perform discovery when this node is started:\u001b[20;1H\u001b(B\u001b[m\u001b[32m68\u001b[20;5H\u001b(B\u001b[m\u001b[30m\u001b[1m The d\u001b[20;12Hfault list of hosts is [\"127.0.0.1\", \"[::1]\"]\u001b[21;1H\u001b(B\u001b[m\u001b[32m69\u001b[22;2H0\u001b[22;5H\u001b(B\u001b[m\u001b[30m\u001b[1mdiscove\u001b[22;13Hy.seed_hosts: [\"host1\",\u001b[22;37H\"host2\"]\u001b(B\u001b[m                             \u001b[23;2H\u001b(B\u001b[m\u001b[32m1\u001b[24;2H2\u001b[24;5H\u001b(B\u001b[m\u001b[30m\u001b[1m Boo\u001b[24;10Hstrap \u001b[24;17Hhe clu\u001b[24;27H using an initial set of master-eligible nodes:\u001b[25;2H\u001b(B\u001b[m\u001b[32m3\u001b[26;2H4\u001b[26;5H\u001b(B\u001b[m\u001b[30m\u001b[1mcluster.in\u001b[26;16Htial_master_n\u001b[2"]

[2664.039431, "o", "      \u001b[29;2H\u001b(B\u001b[m\u001b[32m3\u001b[30;2H4\u001b[30;6H\u001b(B\u001b[m\u001b[30m\u001b[1m---------------------------------- Security\u001b[30;50H----------------------------------\u001b[31;2H\u001b(B\u001b[m\u001b[32m5\u001b[32;2H6\u001b[32;6H\u001b(B\u001b[m\u001b[30m\u001b[1m             \u001b[32;20H        \u001b[32;29H        \u001b[32;38H***\u001b[32;42HWARNING ***\u001b(B\u001b[m            \u001b[33;2H\u001b(B\u001b[m\u001b[32m7\u001b[33;5H\u001b(B\u001b[m                                                                           \u001b[34;1H\u001b(B\u001b[m\u001b[32m88\u001b[34;6H\u001b(B\u001b[m\u001b[30m\u001b[1mEla\u001b[34;10Hticsearc\u001b[34;19H security fea\u001b[34;33Hures are\u001b[34;42Hnot enabled by default.\u001b(B\u001b[m                    \u001b[35;1H\u001b(B\u001b[m\u001b[32m89\u001b[35;6H\u001b(B\u001b[m\u001b[30m\u001b[1mThese featur\u001b[35;19Hs ar\u001b[35;24H free, but require configuration \u001b[35;58Hhang\u001b[35;63Hs to enable them.\u001b[36;2H\u001b(B\u001b[m\u001b[32m0\u001b[36;5H\u001b(B\u001b[m\u001b[30m\u001b[1m This means that users don't have to provide credentials and can get full access\u001b[37;2H\u001b(B\u001b[m\u001b[32m1\u001b[37;6H\u001b(B\u001b[m\u001b[30m\u001b[1mt\u001b[37;9Hthe cluster.\u001b[37;22HNe\u001b[37;25Hwork connections are \u001b[37;47Hlso not encrypt\u001b[37;63Hd.\u001b(B\u001b[m                    \u001b[38;2H\u001b(B\u001b[m\u001b[32m2\u001b[38;5H\u001b(B\u001b[m                        "]
[2664.039448, "o", "                               \u001b[39;2H\u001b(B\u001b[m\u001b[32m3\u001b[39;5H\u001b(B\u001b[m\u001b[30m\u001b[1m To protect your data, we strongly encourage you to enable the Elasticsearch sec\u001b[40;2H\u001b(B\u001b[m\u001b[32m4\u001b[40;6H\u001b(B\u001b[m\u001b[30m\u001b[1mRefer to the following documentation for instructions.\u001b(B\u001b[m                         \u001b[?25l"]
[2664.080167, "o", "\u001b[?25l\u001b[1;2H\u001b(B\u001b[m\u001b[32m3\u001b[1;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch is only accessible on localhost. Set a different\u001b[2;2H\u001b(B\u001b[m\u001b[32m4\u001b[2;5H\u001b(B\u001b[m\u001b[30m\u001b[1m address here\u001b[2;19Hto expose this node on the network:\u001b[3;2H\u001b(B\u001b[m\u001b[32m5\u001b[4;2H6\u001b[4;5H\u001b(B\u001b[m\u001b[30m\u001b[1mnetwork.host: 192.168.0.1\u001b(B\u001b[m                                                   \u001b[5;2H\u001b(B\u001b[m\u001b[32m7\u001b[5;5H\u001b(B\u001b[m                                                       \u001b[6;1H\u001b(B\u001b[m\u001b[32m58\u001b[6;5H\u001b(B\u001b[m\u001b[30m\u001b[1m By default Elasticsearch listens for HTTP traffic on the first free port it\u001b[7;1H\u001b(B\u001b[m\u001b[32m59\u001b[7;5H\u001b(B\u001b[m\u001b[30m\u001b[1m finds s\u001b[7;14Harting at 9200. Set a specific HTTP port here:\u001b[8;2H\u001b(B\u001b[m\u001b[32m0\u001b[9;2H1\u001b[9;5H\u001b(B\u001b[m\u001b[30m\u001b[1mhttp.p\u001b[9;13Ht: 9200\u001b(B\u001b[m                                                 \u001b[10;2H\u001b(B\u001b[m\u001b[32m2\u001b[11;2H3\u001b[11;6H\u001b(B\u001b[m\u001b[30m\u001b[1mFor more information, consult the\u001b[11;40Hnetw\u001b[11;45Hrk module documentation.\u001b(B\u001b[m               \u001b[12;2H\u001b(B\u001b[m\u001b[32m4\u001b[13;2H5\u001b[13;6H\u001b(B\u001b[m\u001b[30m\u001b[1m--------------------------------- Discovery --------------------"]
